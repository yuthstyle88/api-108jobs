><tr><td class=\"header\"><img src=\"https://108jobs.com/_next/static/media/logo.119e38c7.svg\" alt=\"108Jobs Logo\"></td></tr><tr><td class=\"content\"><h1>{title}</h1><p>{message}</p><div class=\"verification-box\"><p style=\"font-size:16px;color:#4b5563;\">{otp_subject}</p><div class=\"otp\">{verification_content}</div><p style=\"font-size:14px;color:#6b7280;\">{otp_body}</p></div><p>{trouble_text}</p><div class=\"divider\"></div><p style=\"font-size:16px;margin-bottom:5px;\">{regards}</p><p style=\"font-size:18px;font-weight:700;color:#1f2a44;\">{team}</p></td></tr><tr><td class=\"subfooter\">{sent_to}</td></tr><tr><td class=\"footer\"><div class=\"footer-links\"><a href=\"#\">{privacy_policy}</a> | <a href=\"#\">{terms_of_service}</a> | <a href=\"#\">{contact_us}</a></div><p>{copyright}</p></td></tr></table></body></html>",
